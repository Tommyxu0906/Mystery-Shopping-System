# Copy to .env and fill in. The system works without any of these
# (mock provider + heuristic extractor are the defaults).

# When set, real LLM extraction runs instead of the heuristic fallback.
OPENAI_API_KEY=

# When set AND CALL_PROVIDER=vapi, real calls are placed via Vapi.
# Default is the mock provider — no money spent.
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
VAPI_ASSISTANT_ID=

# mock | vapi
CALL_PROVIDER=mock

# Path overrides (mostly for tests)
DB_PATH=./mystery_shop.db
